import sys
from google_auth_oauthlib.flow import InstalledAppFlow
from google.auth.transport.requests import Request
from google.oauth2.credentials import Credentials

# 🐉 Ghidorah Mesh: Headless OAuth Generator (v1.4.2)
# Role: Forces the URL to display in SSH without buffering.

SCOPES = ['https://www.googleapis.com/auth/drive.file']
BASE_DIR = os.path.expanduser("~/ghidorah_sentry")
CRED_FILE = os.path.join(BASE_DIR, 'credentials.json')
TOKEN_FILE = os.path.join(BASE_DIR, 'token.json')

def loud_print(msg):
    print(f"🐉 {msg}")
    sys.stdout.flush()

def main():
    loud_print("OAUTH BOOTSTRAP INITIATED...")
    
    if not os.path.exists(CRED_FILE):
        loud_print(f"🚨 ERROR: {CRED_FILE} is missing!")
        return

    creds = None
    if os.path.exists(TOKEN_FILE):
        loud_print("Found existing token, checking validity...")
        creds = Credentials.from_authorized_user_file(TOKEN_FILE, SCOPES)
    
    if not creds or not creds.valid:
        if creds and creds.expired and creds.refresh_token:
            loud_print("Refreshing expired token...")
            creds.refresh(Request())
        else:
            loud_print("No valid token. Launching Headless Auth Flow...")
            flow = InstalledAppFlow.from_client_secrets_file(CRED_FILE, SCOPES)
            
            # CRITICAL: open_browser=False forces the URL to the console
            creds = flow.run_local_server(
                port=0, 
                open_browser=False, 
                success_message="✨ Ghidorah Handshake Complete. You may close this tab."
            )
            
        with open(TOKEN_FILE, 'w') as token:
            token.write(creds.to_json())
            
    loud_print(f"✅ SUCCESS: {TOKEN_FILE} is generated.")

if __name__ == '__main__':
    main()
