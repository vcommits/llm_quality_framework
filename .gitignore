# --- Python Virtual Environment ---
# This is the most important one. Never commit your virtual environment.
.venv/
venv/
ENV/

# --- Python Cache Files ---
# These are temporary files Python creates that don't need to be in the repo.
__pycache__/
*.pyc
*.pyo
*.pyd

# --- IDE / Editor Specific Files ---
# Ignore PyCharm's project configuration files.
.idea/

# --- Robot Framework Output ---
# Ignore the log and report files generated by Robot Framework runs.
output.xml
log.html
report.html
Results/
results/

# --- Sensitive Information ---
# A critical best practice is to always ignore .env files,
# even if you are using system environment variables.
.env
*.env

# --- Local Test Data (Your IP) ---
# You can add specific files or patterns here to make extra sure
# you don't accidentally commit your private test scenarios.
# For example, if you create a prompts file you want to keep private:
# prompts.yaml


# Secrets and Environment Configs
.env
.env.py
agentic_red_team/.env
agentic_red_team/.env.py
**/__pycache__/
*.pyc